<?xml version="1.0"?>
<robot name="simple_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

        <xacro:include filename="$(find car)/model/slam-robot/gazebo.xacro"/>

        <link name="base_footprint"/>

        <material name="blue">
                <color rgba="0 0 1 1"/>
        </material>

        <material name="red">
                <color rgba="1 0 0 1"/>
        </material>

        <material name="green">
                <color rgba="0 1 0 1"/>
        </material>

        <material name="yellow">
                <color rgba="1 1 0 1"/>
        </material>

        <material name="magenta">
                <color rgba="1 0 1 1" />
        </material>

        <material name="cyan">
                <color rgba="0 1 1 1" />
        </material>

        <material name="white">
                <color rgba="1 1 1 1" />
        </material>


        <link name="base_link">
                <visual>
                        <geometry>
                                <box size="1.5 1 0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                        <material name="red"/>
                </visual>

                <collision>
                        <geometry>
                                <box size="1.5 1 0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                </collision>
                
                <inertial>
                        <mass value="10"/>
                        <inertia ixx="0.87" iyy="2.13" izz="2.58" ixy="0.0" ixz="0.0" iyz="0.0"/>
                </inertial>
        </link>

        <joint name="base_joint" type="fixed">
                <parent link="base_footprint"/>
                <child link="base_link"/>
                <origin xyz="0 0 0.5" rpy="0 0 0"/>
        </joint>

        <link name="front_visual">
                <visual>
                        <geometry>
                                <box size="0.25 0.75 0.1"/>
                        </geometry>
                </visual>
        </link>
        <joint name="front_visual_joint" type="fixed">
                <parent link="base_link"/>
                <child link="front_visual"/>
                <origin xyz="0.5 0 0.15" rpy="0 0 0"/>
        </joint>

        
        <!-- WHEELS -->

        <link name="rf_link">
                <visual>
                        <geometry>
                                <cylinder radius="0.25" length="0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                        <material name="blue"/>
                </visual>
                <collision>
                        <geometry>
                                <cylinder radius="0.25" length="0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                </collision>
                
                <inertial>
                        <mass value="5"/>
                        <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0.0" ixz="0.0" iyz="0.0"/>
                </inertial>
        </link>

        <link name="rf_rotation_link">
                <visual>
                        <geometry>
                                <box size="0.1 0.1 0.1"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                </visual>
        </link>

        <link name="rb_link">
                <visual>
                        <geometry>
                                <cylinder radius="0.25" length="0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                        <material name="blue"/>
                </visual>
                <collision>
                        <geometry>
                                <cylinder radius="0.25" length="0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                </collision>
                
                <inertial>
                        <mass value="5"/>
                        <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0.0" ixz="0.0" iyz="0.0"/>
                </inertial>
        </link>

        <link name="rb_rotation_link">
                <visual>
                        <geometry>
                                <box size="0.1 0.1 0.1"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                </visual>
        </link>

        <link name="lf_link">
                <visual>
                        <geometry>
                                <cylinder radius="0.25" length="0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                        <material name="blue"/>
                </visual>
                <collision>
                        <geometry>
                                <cylinder radius="0.25" length="0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                </collision>
                
                <inertial>
                        <mass value="5"/>
                        <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0.0" ixz="0.0" iyz="0.0"/>
                </inertial>
        </link>

        <link name="lf_rotation_link">
                <visual>
                        <geometry>
                                <box size="0.1 0.1 0.1"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                </visual>
        </link>

        <link name="lb_link">
                <visual>
                        <geometry>
                                <cylinder radius="0.25" length="0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                        <material name="blue"/>
                </visual>
                <collision>
                        <geometry>
                                <cylinder radius="0.25" length="0.2"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                </collision>
                
                <inertial>
                        <mass value="5"/>
                        <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0.0" ixz="0.0" iyz="0.0"/>
                </inertial>
        </link>

        <link name="lb_rotation_link">
                <visual>
                        <geometry>
                                <box size="0.1 0.1 0.1"/>
                        </geometry>
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                </visual>
        </link>


        <joint name="rb_joint" type="continuous">
                <parent link="base_link"/>
                <child link="rb_link"/>
                <origin xyz="-0.5 -0.5 -0.25" rpy="0 0 ${-pi/4}"/>
                <axis xyz="0 -1 0"/>
                <dynamics damping="1.0" friction="1.0"/>
                <limit effort="1000" velocity="1000"/>   
        </joint>
        <joint name="rb_rotation_joint" type="fixed">
                <parent link="rb_link"/>
                <child link="rb_rotation_link"/>
                <origin xyz="0 -0.1 0" rpy="0 0 0"/>
        </joint>


        <joint name="rf_joint" type="continuous">
                <parent link="base_link"/>
                <child link="rf_link"/>
                <origin xyz="0.5 -0.5 -0.25" rpy="0 0 ${pi/4}"/>
                <axis xyz="0 -1 0"/>
                <dynamics damping="1.0" friction="1.0"/>
                <limit effort="1000" velocity="1000"/>    
        </joint>
        <joint name="rf_rotation_joint" type="fixed">
                <parent link="rf_link"/>
                <child link="rf_rotation_link"/>
                <origin xyz="0 -0.1 0" rpy="0 0 0"/>
        </joint>


        <joint name="lb_joint" type="continuous">
                <parent link="base_link"/>
                <child link="lb_link"/>
                <origin xyz="-0.5 0.5 -0.25" rpy="0 0 ${pi/4}"/>
                <axis xyz="0 1 0"/>
                <dynamics damping="1.0" friction="1.0"/>
                <limit effort="1000" velocity="1000"/>   
        </joint>
        <joint name="lb_rotation_joint" type="fixed">
                <parent link="lb_link"/>
                <child link="lb_rotation_link"/>
                <origin xyz="0 0.1 0" rpy="0 0 0"/>
        </joint>


        <joint name="lf_joint" type="continuous">
                <parent link="base_link"/>
                <child link="lf_link"/>
                <origin xyz="0.5 0.5 -0.25" rpy="0 0 ${-pi/4}"/>
                <axis xyz="0 1 0"/>
                <dynamics damping="1.0" friction="1.0"/>
                <limit effort="1000" velocity="1000"/>   
        </joint>
        <joint name="lf_rotation_joint" type="fixed">
                <parent link="lf_link"/>
                <child link="lf_rotation_link"/>
                <origin xyz="0 0.1 0" rpy="0 0 0"/>
        </joint>


        <!-- LIDAR -->
        <link name="lidar_link">
                <visual>
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                        <geometry>
                                <cylinder length="0.3" radius="0.25"/>
                        </geometry>
                        <material name="green"/>
                </visual>
                <collision name="collision">
                        <origin xyz="0 0 0" rpy="0 0 0"/>
                        <geometry>
                                <cylinder length="0.3" radius="0.25"/>
                        </geometry>
                </collision>
        </link>

        <joint name="lidar_joint" type="fixed">
                <parent link="base_link"/>
                <child link="lidar_link"/>
                <origin xyz="0 0 0.25" rpy="0 0 0"/>
        </joint>


        <!-- ROS2 CONTROL -->

        <ros2_control name="RobotController" type="system">
                <hardware>
                        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
                </hardware>

                <joint name="lf_joint">
                        <command_interface name="velocity"/>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                </joint>

                <joint name="rf_joint">
                        <command_interface name="velocity"/>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                </joint>

                <joint name="rb_joint">
                        <command_interface name="velocity"/>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                </joint>

                <joint name="lb_joint">
                        <command_interface name="velocity"/>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                </joint>


        </ros2_control>

</robot>